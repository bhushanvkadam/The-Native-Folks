<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --cream: #F2ECD9;
    --warm: #EDE3CC;
    --green-dark: #1C3022;
    --green-mid: #2D4A35;
    --green-light: #4A7055;
    --gold: #C8923A;
    --text: #1C2418;
    --text-light: #5A6B52;
  }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); overflow-x: hidden; }

  /* NAV */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 200;
    padding: 12px 64px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(28,48,34,0.97);
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
  }
  .nav-logo img {
    height: 64px; width: auto;
    mix-blend-mode: screen;
  }
  .nav-links { display: flex; gap: 32px; list-style: none; align-items: center; }
  .nav-links a {
    text-decoration: none; font-size: 0.78rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255,255,255,0.75); transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta {
    background: var(--gold) !important; color: white !important;
    padding: 10px 24px; border-radius: 2px;
  }
  .nav-cta:hover { background: #a87530 !important; }

  /* HERO */
  #hero { height: 100vh; min-height: 640px; position: relative; display: flex; align-items: flex-end; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background: url('data:image/jpeg;base64,') center center / cover no-repeat; }
  .hero-bg::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(18,32,20,0.15) 0%, rgba(18,32,20,0.05) 40%, rgba(18,32,20,0.75) 100%);
  }
  .hero-content { position: relative; z-index: 2; padding: 0 64px 80px; max-width: 900px; }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 0.72rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.7); margin-bottom: 20px;
  }
  .hero-eyebrow::before, .hero-eyebrow::after { content: ''; display: block; width: 24px; height: 1px; background: var(--gold); }
  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(5rem, 12vw, 10rem); line-height: 0.92;
    color: white; letter-spacing: 0.02em; margin-bottom: 28px;
    animation: heroIn 1s ease both;
  }
  .hero-sub {
    font-family: 'Crimson Pro', serif; font-style: italic; font-size: 1.2rem; font-weight: 300;
    color: rgba(255,255,255,0.82); max-width: 520px; line-height: 1.7;
    margin-bottom: 40px; animation: heroIn 1s 0.15s ease both;
  }
  .hero-buttons { display: flex; gap: 14px; flex-wrap: wrap; animation: heroIn 1s 0.3s ease both; }

  /* BUTTONS */
  .btn-dark {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--green-dark); color: var(--cream);
    padding: 14px 28px; border-radius: 2px; text-decoration: none;
    font-size: 0.8rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    transition: all 0.25s; border: 1px solid rgba(255,255,255,0.1);
  }
  .btn-dark:hover { background: var(--green-mid); transform: translateY(-2px); }
  .btn-dark .logo-img { height: 20px; width: auto; mix-blend-mode: screen; }

  .btn-glass {
    display: inline-flex; align-items: center; gap: 10px;
    background: rgba(255,255,255,0.12); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.25); color: white;
    padding: 14px 28px; border-radius: 2px; text-decoration: none;
    font-size: 0.8rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    transition: all 0.25s;
  }
  .btn-glass:hover { background: rgba(255,255,255,0.2); }
  .btn-glass .logo-img { height: 20px; width: auto; mix-blend-mode: screen; }

  .btn-outline {
    display: inline-flex; align-items: center; gap: 10px;
    background: transparent; border: 1.5px solid var(--green-dark); color: var(--green-dark);
    padding: 13px 26px; border-radius: 2px; text-decoration: none;
    font-size: 0.78rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    transition: all 0.25s;
  }
  .btn-outline:hover { background: rgba(28,48,34,0.06); }
  .btn-outline .logo-img { height: 20px; width: auto; mix-blend-mode: multiply; }

  /* HERO SCROLL */
  .hero-scroll {
    position: absolute; right: 64px; bottom: 80px; z-index: 2;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }
  .scroll-line { width: 1px; height: 48px; background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent); animation: scrollPulse 2s ease-in-out infinite; }

  /* PRODUCT */
  #product { padding: 120px 64px; background: var(--cream); }
  .product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .product-img-bg {
    width: 100%; aspect-ratio: 3/4;
    background: var(--warm); border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; border: 1px solid rgba(28,48,34,0.08);
  }
  .product-img-bg img { width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 8px 24px rgba(0,0,0,0.15)); }
  .product-badge {
    position: absolute; top: -16px; right: -16px;
    width: 72px; height: 72px; background: var(--green-dark); border-radius: 50%;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    font-size: 0.6rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--gold); text-align: center; line-height: 1.4;
  }
  .product-img-wrap { position: relative; }
  .product-meta { display: flex; gap: 28px; margin-top: 24px; }
  .meta-item { text-align: center; padding: 14px 20px; background: var(--green-dark); border-radius: 2px; flex: 1; }
  .meta-val { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; color: var(--gold); letter-spacing: 0.05em; }
  .meta-label { font-size: 0.62rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(242,236,217,0.55); margin-top: 2px; }

  .section-tag { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green-light); display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .section-tag::before { content: ''; width: 28px; height: 1px; background: var(--green-light); }
  .product-name { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.4rem, 4vw, 3.6rem); line-height: 1.0; color: var(--green-dark); margin-bottom: 6px; letter-spacing: 0.03em; }
  .product-origin { font-family: 'Crimson Pro', serif; font-style: italic; font-weight: 300; font-size: 1rem; color: var(--text-light); margin-bottom: 32px; }
  .product-features { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-bottom: 36px; }
  .feature-item { display: flex; align-items: flex-start; gap: 14px; padding-bottom: 14px; border-bottom: 1px solid rgba(28,48,34,0.08); }
  .feature-item:last-child { border-bottom: none; padding-bottom: 0; }
  .feature-icon { width: 32px; height: 32px; flex-shrink: 0; background: rgba(28,48,34,0.06); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; }
  .feature-text strong { display: block; font-size: 0.82rem; font-weight: 500; color: var(--green-dark); margin-bottom: 2px; }
  .feature-text span { font-size: 0.78rem; color: var(--text-light); line-height: 1.5; font-weight: 300; }
  .product-buttons { display: flex; gap: 12px; flex-wrap: wrap; }

  /* STORY */
  #story { background: var(--green-dark); overflow: hidden; }
  .story-top {
    padding: 100px 64px; text-align: center; position: relative;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 40px, rgba(255,255,255,0.018) 40px, rgba(255,255,255,0.018) 41px),
      repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(255,255,255,0.012) 40px, rgba(255,255,255,0.012) 41px),
      radial-gradient(ellipse 70% 80% at 50% 50%, rgba(74,112,85,0.45) 0%, transparent 70%),
      linear-gradient(135deg, #111f14 0%, #1C3022 35%, #25402E 65%, #111f14 100%);
  }
  .story-top::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.025'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
  }
  .story-headline {
    font-family: 'Bebas Neue', sans-serif; font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 1.0; color: var(--cream); letter-spacing: 0.02em; position: relative; z-index: 1;
  }
  .story-headline em {
    font-family: 'Crimson Pro', serif; font-style: italic; font-size: 0.7em;
    color: var(--gold); display: block; letter-spacing: 0.05em;
  }
  .story-body-section { display: grid; grid-template-columns: 1fr 1fr; min-height: 480px; }
  .story-text { padding: 80px 64px; display: flex; flex-direction: column; justify-content: center; }
  .story-p { font-family: 'Crimson Pro', serif; font-size: 1.15rem; font-weight: 300; line-height: 1.9; color: rgba(242,236,217,0.8); margin-bottom: 20px; }
  .story-quote { margin-top: 16px; padding-left: 20px; border-left: 2px solid var(--gold); }
  .story-quote p { font-family: 'Crimson Pro', serif; font-style: italic; font-size: 1.2rem; color: rgba(242,236,217,0.95); line-height: 1.7; }
  .story-quote cite { display: block; margin-top: 10px; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); font-style: normal; }
  .story-image { position: relative; overflow: hidden; }
  .story-image img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; }
  .story-image::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, rgba(28,48,34,0.4), transparent); }

  /* FIND US */
  #findus { padding: 100px 64px; background: var(--warm); text-align: center; }
  .findus-label { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: var(--text-light); margin-bottom: 14px; }
  .findus-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2rem, 4vw, 3.2rem); color: var(--green-dark); letter-spacing: 0.04em; margin-bottom: 56px; }
  .findus-cards { display: flex; justify-content: center; gap: 24px; flex-wrap: wrap; }
  .findus-card {
    text-decoration: none; background: white; border: 1px solid rgba(28,48,34,0.1);
    border-radius: 4px; padding: 40px 56px;
    display: flex; flex-direction: column; align-items: center; gap: 16px; min-width: 260px;
    transition: all 0.3s;
  }
  .findus-card:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(28,48,34,0.12); border-color: var(--green-light); }
  .findus-card .logo-img { height: 36px; width: auto; object-fit: contain; }
  .findus-card .logo-img.dark-bg { mix-blend-mode: multiply; }
  .findus-card-label { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-light); }
  .findus-arrow { font-size: 0.75rem; color: var(--green-light); font-weight: 500; }

  /* CONTACT */
  #contact { padding: 100px 64px; background: var(--cream); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 80px; align-items: start; }
  .contact-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(3rem, 5vw, 5rem); line-height: 0.95; color: var(--green-dark); letter-spacing: 0.02em; margin-bottom: 24px; }
  .contact-body { font-family: 'Crimson Pro', serif; font-size: 1.05rem; font-weight: 300; line-height: 1.8; color: var(--text-light); margin-bottom: 36px; }
  .contact-details { display: flex; flex-direction: column; gap: 12px; }
  .contact-row { display: flex; gap: 12px; align-items: center; font-size: 0.88rem; color: var(--text); }
  .contact-row span:first-child { font-size: 0.68rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--green-light); min-width: 72px; }
  .contact-socials { display: flex; gap: 12px; margin-top: 28px; }
  .social-btn { width: 38px; height: 38px; border: 1px solid rgba(28,48,34,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; font-size: 0.85rem; color: var(--green-dark); transition: all 0.2s; }
  .social-btn:hover { background: var(--green-dark); color: var(--cream); border-color: var(--green-dark); }
  .contact-form { background: var(--green-dark); border-radius: 4px; padding: 48px 44px; }
  .form-group { margin-bottom: 20px; }
  .form-group label { display: block; margin-bottom: 7px; font-size: 0.68rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(242,236,217,0.5); }
  .form-group input, .form-group textarea { width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 2px; padding: 13px 16px; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; color: var(--cream); outline: none; transition: border-color 0.2s; resize: vertical; }
  .form-group input::placeholder, .form-group textarea::placeholder { color: rgba(242,236,217,0.25); }
  .form-group input:focus, .form-group textarea:focus { border-color: var(--gold); }
  .form-group textarea { min-height: 100px; }
  .form-btn { width: 100%; padding: 15px; background: var(--gold); color: white; border: none; border-radius: 2px; font-family: 'DM Sans', sans-serif; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer; transition: all 0.25s; margin-top: 4px; }
  .form-btn:hover { background: #a87530; transform: translateY(-1px); }

  /* FOOTER */
  footer { background: #111C13; padding: 64px 64px 32px; color: rgba(242,236,217,0.5); }
  .footer-top { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.07); margin-bottom: 28px; }
  .footer-logo img { height: 64px; width: auto; margin-bottom: 16px; mix-blend-mode: screen; }
  .footer-tagline { font-family: 'Crimson Pro', serif; font-style: italic; font-size: 0.95rem; line-height: 1.6; color: rgba(242,236,217,0.4); }
  .footer-col h4 { font-size: 0.68rem; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold); margin-bottom: 18px; }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .footer-col a { text-decoration: none; font-size: 0.84rem; color: rgba(242,236,217,0.45); transition: color 0.2s; }
  .footer-col a:hover { color: var(--cream); }
  .footer-bottom { display: flex; justify-content: space-between; font-size: 0.75rem; color: rgba(242,236,217,0.25); }

  /* UTILS */
  .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity: 1; transform: none; }
  @keyframes heroIn { from { opacity: 0; transform: translateY(32px); } to { opacity: 1; transform: none; } }
  @keyframes scrollPulse { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    nav { padding: 12px 24px; }
    .nav-links { display: none; }
    #product, #findus, #contact { padding: 80px 24px; }
    .product-grid { grid-template-columns: 1fr; gap: 40px; }
    .story-body-section { grid-template-columns: 1fr; }
    .story-image { min-height: 300px; }
    .story-top { padding: 80px 24px; }
    .story-text { padding: 60px 24px; }
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    footer { padding: 48px 24px 24px; }
    .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer-bottom { flex-direction: column; gap: 8px; }
    .hero-content { padding: 0 24px 60px; }
    .hero-scroll { display: none; }
  }
</style>
</head>
